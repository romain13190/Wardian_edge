# Wardian Edge — Environment Variables
# Generated by setup.sh or configured manually.

# Deployment mode:
#   cloud  = MCPs self-register to Cloud via HTTP (no gateway needed)
#   onprem = MCPs accessed via Gateway WebSocket relay
EDGE_MODE=onprem

# Required for onprem mode: Get from Wardian admin dashboard
ORG_TOKEN=wdn_gw_your_token_here
CLOUD_URL=wss://app.wardian.ai/ws/gateway

# Required for cloud mode: HTTP URL of Wardian Cloud
# WARDIAN_CLOUD_URL=https://app.wardian.ai
# MCP_REGISTRY_TOKEN=

# Required: LLM API key
CHUTES_API_KEY=your_chutes_api_key
CHUTES_BASE_URL=https://llm.chutes.ai/v1

# Database (defaults are fine for local Docker)
POSTGRES_PASSWORD=wardian2026

# MinIO / S3 (defaults are fine for local Docker)
MINIO_ROOT_USER=wardian
MINIO_ROOT_PASSWORD=wardian2026

# Enable/disable optional MCP servers
ENABLE_GMAIL_MCP=false
ENABLE_DRIVE_MCP=false
ENABLE_GITHUB_MCP=false
ENABLE_PHARMACY_MCP=false
# Google (Gmail / Drive) — choose one auth mode:
#   service_account: domain-wide delegation (recommended for enterprise)
#   oauth: per-user OAuth flow (each user connects individually)
GMAIL_AUTH_MODE=oauth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Service account mode only:
GOOGLE_SERVICE_ACCOUNT_KEY=
DRIVE_TARGET_USER=

ENABLE_PIPEDRIVE_MCP=false
ENABLE_ERPLAIN_MCP=false
ENABLE_PENNYLANE_MCP=false

# Pipedrive CRM (get token from: Pipedrive > Settings > Personal preferences > API)
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=

# Erplain Stock (get token from: Erplain > Profile > Edit my profile > Generate token)
ERPLAIN_API_TOKEN=

# Pennylane Compta (get token from: Pennylane > Settings > API)
PENNYLANE_API_TOKEN=

# Integration credential encryption — Fernet key, 32 url-safe base64-encoded bytes
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# INTEGRATION_ENCRYPTION_KEY=

# Auto-update (Watchtower)
# GHCR_TOKEN: read-only token for pulling images from ghcr.io
# Generate at: https://github.com/settings/tokens (scope: read:packages)
GHCR_TOKEN=
WATCHTOWER_POLL_INTERVAL=21600  # seconds (default: 6h = 21600)
# Optional: notification URL (slack, email, etc.)
# See https://containrrr.dev/shoutrrr/services/overview/
# WATCHTOWER_NOTIFICATION_URL=
